{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Authentication": {
    "Issuer": "http://progresium-api-test",
    "Audience": "http://progresium-api-test"
  },
  "Mailtrap": {
    "ApiUrl": "https://send.api.mailtrap.io/api/",
    "NoReplyEmail": "no-reply@progresium.com",
    "ContactUsEmail": "contact@progresium.com",
    "SenderName": "Progresium Team",
    "EmailCooldownInSeconds": 60,
    "VerificationCodeLifespanInMinutes": 15
  },
  "RateLimiting": {
    "ContactUsPolicy": {
      "PermitLimit": 5,
      "WindowInMinutes": 5
    },
    "ResetPasswordPolicy": {
      "PermitLimit": 10,
      "WindowInMinutes": 5
    }
  },
  "AllowedHosts": "*"
}
